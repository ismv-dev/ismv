---
import { SITE_TITLE } from '../consts';
---

<header>
	<nav aria-label="Navegación principal">
		<a href="#perfil">Perfil</a>
		<a href="#habilidades">Habilidades</a>
		<a href="#experiencia">Experiencia</a>
		<a href="#contacto">Contacto</a>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 10;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1rem 1.5rem;
		backdrop-filter: blur(2px);
		background: #11182735;
	}
	.home-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.75rem;
		height: 2.75rem;
		border-radius: 999px;
		background: #1f4ed8;
		color: #f8f7ff;
		font-weight: 800;
		box-shadow: 0 10px 25px rgba(31, 78, 216, 0.3);
	}
	nav {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
		justify-content: flex-end;
	}
	nav a {
		padding: 0.7rem 1rem;
		border-radius: 999px;
		background: #0000002c;
		color: #ffffff;
		font-weight: 600;
		text-decoration: none;
		transition: transform 180ms ease, box-shadow 180ms ease;
	}
	nav a:hover,
	nav a:focus-visible {
		transform: scale(1.05);
		box-shadow: 0 0 20px #8b8b8b56;
		background: #8b8b8b56;
	}
	@media (max-width: 720px) {
		header {
			padding: 0.75rem 0.85rem;
			justify-content: center;
		}
		nav {
			justify-content: center;
			gap: 0.4rem;
			width: 100%;
		}
		nav a {
			padding: 0.55rem 0.7rem;
			font-size: 0.9rem;
			line-height: 1;
		}
	}

	@media (max-width: 480px) {
		header {
			padding: 0.7rem 0.6rem;
		}
		nav {
			flex-wrap: wrap;
			gap: 0.35rem;
		}
		nav a {
			flex: 1 1 calc(50% - 0.35rem);
			text-align: center;
			padding: 0.6rem 0.5rem;
			font-size: 0.85rem;
		}
	}
</style>
